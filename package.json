{
  "name": "app-bff",
  "version": "1.0.1",
  "description": "BFF que agrega catalog + reviews com graceful degradation — referência de plataforma engineering",
  "main": "src/index.js",
  "scripts": {
    "start": "node --require @opentelemetry/auto-instrumentations-node/register src/index.js",
    "dev": "node --require @opentelemetry/auto-instrumentations-node/register --watch src/index.js"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "fastify": "^5.7.2",
    "prom-client": "^15.1.3",
    "undici": "^6.21.0"
  },
  "overrides": {
    "cross-spawn": ">=7.0.5",
    "minimatch": ">=9.0.7",
    "tar": ">=7.5.11",
    "glob": ">=11.1.0"
  }
}
